# ============================================================
#  DALY BMS BLACK BOX - Configuration
# ============================================================

# --- BMS / Serial ---
BMS_SERIAL_PORT=/dev/ttyUSB0
BMS_SERIAL_BAUD=9600
BMS_CELL_COUNT=24
BMS_POLL_INTERVAL=5          # seconds between polls
BMS_POLL_TIMEOUT=10          # seconds before a poll is considered failed

# --- Data Retention ---
DB_PATH=data/bms.db
RETENTION_DAYS=90            # delete records older than N days (0 = keep forever)
RETENTION_CHECK_INTERVAL=3600  # how often to run retention cleanup (seconds)

# --- Web Server ---
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false
SECRET_KEY=change-me-to-something-random-and-long

# --- Authentication ---
WEB_USERNAME=admin
WEB_PASSWORD=changeme         # CHANGE THIS

# --- Logging ---
LOG_LEVEL=INFO                # DEBUG, INFO, WARNING, ERROR
LOG_FILE=logs/blackbox.log
LOG_MAX_BYTES=10485760        # 10 MB
LOG_BACKUP_COUNT=5

# --- Alerts (future use) ---
ALERT_LOW_SOC=15              # % SOC to trigger low battery warning
ALERT_HIGH_TEMP=45            # celsius
ALERT_CELL_VOLTAGE_DIFF=0.1   # volts - max spread before balancing alert
